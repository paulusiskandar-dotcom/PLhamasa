extends master

block content
  script.
    var plmPageData = { priceListId: !{JSON.stringify(page.data.priceListId || null)} };

  div.eg-wrapper(ng-controller="editGroupedController")

    div.toast-container(ng-if="toast.show")
      div.toast-msg(ng-class="'toast-' + toast.type") {{ toast.message }}

    //- Loading state
    div.eg-loading(ng-if="loading")
      i.bi.bi-arrow-clockwise.spinning
      |  Memuat data...

    div(ng-if="!loading")

      //- Header card
      div.eg-header-card
        div.eg-header-top
          div.eg-header-title
            button.btn-back(ng-click="goBack()")
              i.bi.bi-arrow-left
            h2.eg-cat-name
              | {{ pl.cat_name }}
              span.eg-rev  Rev.{{ pl.revision_no | padNumber:3 }}
            span.status-badge.status-open OPEN
          div.eg-header-actions
            button.btn-secondary(ng-click="goBack()")
              i.bi.bi-check-circle
              |  Selesai Edit
            button.btn-primary(ng-click="initiatePostToErp()")
              i.bi.bi-cloud-upload
              |  Post to ERP
        div.eg-header-info
          span.info-item
            i.bi.bi-collection
            |  {{ groups.length }} groups · {{ totalItemCount() }} item
          span.info-item.warning(ng-if="undetectedItems.length > 0")
            i.bi.bi-exclamation-triangle
            |  {{ undetectedItems.length }} item belum di-assign

      //- Toolbar
      div.eg-toolbar
        div.search-wrapper
          i.bi.bi-search
          input.search-input(type="text" ng-model="searchQuery" placeholder="Cari nama barang...")
          button.search-clear(ng-click="searchQuery = ''" ng-if="searchQuery")
            i.bi.bi-x
        div.eg-toolbar-actions
          button.btn-ghost.btn-small(ng-click="toggleSelectAllGroups()")
            i.bi(ng-class="allGroupsChecked() ? 'bi-check-square' : 'bi-square'")
            |  {{ allGroupsChecked() ? 'Uncheck Semua' : 'Pilih Semua' }}
          button.btn-ghost.btn-small(
            ng-click="sortGroup = 'thickness_asc'"
            ng-class="{active: sortGroup === 'thickness_asc'}")
            | Tebal ↑
          button.btn-ghost.btn-small(
            ng-click="sortGroup = 'thickness_desc'"
            ng-class="{active: sortGroup === 'thickness_desc'}")
            | Tebal ↓
          button.btn-secondary.btn-small(ng-click="openCreateGroupModal()")
            i.bi.bi-plus-circle
            |  Group Manual

      //- Modifier bar
      div.modifier-bar(ng-if="groups.length > 0")
        div.modifier-title
          i.bi.bi-magic
          |  Pengubah Harga
        div.modifier-row
          div.modifier-targets
            span.mod-target-label Target:
            label.mod-checkbox(ng-repeat="pt in priceTypes")
              input(type="checkbox" ng-model="modifier.targets[pt.code]")
              span  {{ pt.label }}
              span.text-muted(ng-if="isExtendedCategory")  ({{ pt.group }})
            button.btn-ghost.btn-sm(ng-click="selectAllTargets()") Semua
            button.btn-ghost.btn-sm(ng-if="isExtendedCategory" ng-click="selectGudangTargets()") Gudang
            button.btn-ghost.btn-sm(ng-if="isExtendedCategory" ng-click="selectPabrikTargets()") Pabrik
          div.modifier-input-row
            select.mod-type.form-control(ng-model="modifier.type" ng-options="m.id as m.label for m in modifierTypes")
            input.mod-value.form-control(
              type="text"
              ng-model="modifier.value"
              placeholder="Nilai")
            button.btn-generate-gold(
              ng-click="applyModifier()"
              ng-disabled="!hasSelectedGroups() || !modifier.value")
              i.bi.bi-lightning-fill
              |  Generate
            span.mod-summary(ng-if="selectedGroupCount() > 0") {{ selectedGroupCount() }} group dipilih

      //- Detection banner
      div.eg-detection-banner(ng-if="detection.new_items.length > 0 || detection.removed_items.length > 0")
        div.banner-content
          i.bi.bi-bell-fill
          div.banner-text
            strong(ng-if="detection.new_items.length > 0") {{ detection.new_items.length }} item baru terdeteksi
            span(ng-if="detection.new_items.length > 0 && detection.removed_items.length > 0")  ·
            strong.text-danger(ng-if="detection.removed_items.length > 0") {{ detection.removed_items.length }} item dihapus dari ERP
          button.btn-primary.btn-small(ng-if="detection.new_items.length > 0" ng-click="openReviewModal()")
            i.bi.bi-list-check
            |  Review & Assign
          button.btn-ghost.btn-small(ng-click="loadDetection()")
            i.bi.bi-arrow-clockwise
            |  Refresh

      //- Groups list
      div.eg-groups-wrapper
        div.eg-empty-state(ng-if="groups.length === 0")
          i.bi.bi-inbox
          |  Belum ada group. Init groups di Settings dulu.
        div.eg-group-card(ng-repeat="g in groups | groupSort:sortGroup")
          div.eg-group-header(
            ng-class="{expanded: g._expanded}")
            div.egh-left
              div.egh-checkbox
                input(type="checkbox" ng-model="g._checked" ng-click="$event.stopPropagation()")
              button.btn-toggle-expand(ng-click="toggleGroup(g)")
                i.bi(ng-class="g._expanded ? 'bi-chevron-down' : 'bi-chevron-right'")
              span.egh-thickness {{ g.thickness_label }}
              span.egh-count {{ g.items.length }}
            div.egh-right
              div.egh-price-input(ng-if="isExtendedCategory")
                label Cash Pabrik
                input(type="number" ng-model="g.cash_pabrik_kg" ng-change="onGroupPriceChange(g)" placeholder="0")
              div.egh-price-input
                label Cash Gudang
                input(type="number" ng-model="g.cash_gudang_kg" ng-change="onGroupPriceChange(g)" placeholder="0")
              div.egh-price-input(ng-if="isExtendedCategory")
                label Kredit Pabrik
                input(type="number" ng-model="g.kredit_pabrik_kg" ng-change="onGroupPriceChange(g)" placeholder="0")
              div.egh-price-input
                label Kredit Gudang
                input(type="number" ng-model="g.kredit_gudang_kg" ng-change="onGroupPriceChange(g)" placeholder="0")
              button.btn-icon-mini.btn-danger(
                ng-if="g.items.length === 0"
                ng-click="$event.stopPropagation(); deleteGroup(g)"
                title="Hapus group kosong")
                i.bi.bi-trash
              span.save-indicator(ng-if="g._saving")
                i.bi.bi-arrow-clockwise.spinning
              span.save-indicator.saved(ng-if="!g._saving && g._saved")
                i.bi.bi-check-circle-fill

          //- Expanded detail table
          div.eg-group-detail(ng-if="g._expanded")
            div.eg-empty-detail(ng-if="g.items.length === 0") Group ini belum punya item
            table.eg-detail-table(ng-if="g.items.length > 0")
              thead
                tr
                  th(ng-click="setSortItem(g, 'i_name')" ng-class="getItemSortClass(g, 'i_name')") NAMA BARANG
                  th.text-right(ng-click="setSortItem(g, 'i_weight')" ng-class="getItemSortClass(g, 'i_weight')") BERAT
                  th.text-right(ng-if="isExtendedCategory") CP /LBR
                  th.text-right CG /LBR
                  th.text-right(ng-if="isExtendedCategory") KP /LBR
                  th.text-right KG /LBR
                  th(style="width:32px")
              tbody
                tr(ng-repeat="it in g.items | orderBy:g._itemSort:g._itemSortReverse | itemNameFilter:searchQuery")
                  td {{ it.i_name }}
                  td.text-right.mono {{ it.i_weight | number:2 }} kg
                  td.text-right.mono(ng-if="isExtendedCategory") {{ it.cash_pabrik_lbr | thousand }}
                  td.text-right.mono {{ it.cash_gudang_lbr | thousand }}
                  td.text-right.mono(ng-if="isExtendedCategory") {{ it.kredit_pabrik_lbr | thousand }}
                  td.text-right.mono {{ it.kredit_gudang_lbr | thousand }}
                  td.text-center
                    button.btn-icon-mini(ng-click="openMoveItemModal(it, g)" title="Pindah ke group lain")
                      i.bi.bi-arrow-left-right

      //- Footer: undetected items
      div.eg-footer-section(ng-if="undetectedItems.length > 0")
        div.eg-footer-warning
          i.bi.bi-exclamation-triangle-fill
          |  {{ undetectedItems.length }} item belum di-assign group:
          button.btn-ghost.btn-small(ng-click="showUndetected = !showUndetected")
            | {{ showUndetected ? 'Tutup' : 'Lihat' }}
        div.eg-undetected-list(ng-if="showUndetected")
          div.und-item(ng-repeat="it in undetectedItems")
            span.und-name {{ it.i_name }}
            small.muted  ({{ it.i_weight | number:2 }} kg)
            select.und-select(ng-model="it._selectedGroup" ng-change="onUndetectedGroupChange(it)")
              option(value="") -- Pilih group --
              option(ng-repeat="g in groups" value="{{ g.id }}") {{ g.thickness_label }}
              option(value="__new__" style="color:#F57C00; font-weight:600;") + Buat group baru...
            div.und-create-form(ng-if="it._selectedGroup === '__new__'")
              input(
                type="number"
                step="0.01"
                placeholder="Tebal mm"
                ng-model="it._newThickness"
                ng-keyup="$event.key === 'Enter' && executeCreateAndAssign(it)")
              button.btn-primary.btn-small(
                ng-click="executeCreateAndAssign(it)"
                ng-disabled="!it._newThickness || it._creating")
                i.bi.bi-arrow-clockwise.spinning(ng-if="it._creating")
                i.bi.bi-check(ng-if="!it._creating")
                |  Buat & Assign
              button.btn-ghost.btn-small(ng-click="cancelCreateNew(it)") Batal

    //- Modal: Create group
    div.modal-overlay(ng-if="modalCreateGroup" ng-click="closeCreateGroupModal()")
      div.modal-card.modal-small(ng-click="$event.stopPropagation()")
        div.modal-header
          h3 Buat Group Manual
          button.modal-close(ng-click="closeCreateGroupModal()") ×
        div.modal-body
          div.form-group
            label Tebal (mm)
            input.form-control(type="number" ng-model="modalCreateGroup.thickness" step="0.01" placeholder="2.30" autofocus)
            small.form-hint Contoh: 2.30 untuk plat 2.30 mm
        div.modal-actions
          button.btn-ghost(ng-click="closeCreateGroupModal()") Batal
          button.btn-primary(
            ng-click="executeCreateGroup()"
            ng-disabled="!modalCreateGroup.thickness || modalCreateGroup.executing")
            | Buat Group

    //- Modal: Move item
    div.modal-overlay(ng-if="modalMoveItem" ng-click="closeMoveItemModal()")
      div.modal-card.modal-small(ng-click="$event.stopPropagation()")
        div.modal-header
          h3 Pindah Item ke Group Lain
          button.modal-close(ng-click="closeMoveItemModal()") ×
        div.modal-body
          p
            strong {{ modalMoveItem.item.i_name }}
            small.muted  ({{ modalMoveItem.item.i_weight | number:2 }} kg)
          p
            | Saat ini di group:
            strong  {{ modalMoveItem.fromGroup.thickness_label }}
          div.form-group
            label Pindah ke group:
            select.form-control(ng-model="modalMoveItem.toGroupId")
              option(value="") -- Pilih group --
              option(ng-repeat="g in groups" ng-if="g.id !== modalMoveItem.fromGroup.id" value="{{ g.id }}") {{ g.thickness_label }} ({{ g.items.length }} item)
        div.modal-actions
          button.btn-ghost(ng-click="closeMoveItemModal()") Batal
          button.btn-primary(ng-click="executeMoveItem()" ng-disabled="!modalMoveItem.toGroupId")
            | Pindahkan

    //- Modal: Review new items
    div.modal-overlay(ng-if="modalReview" ng-click="closeReviewModal()")
      div.modal-card.modal-large(ng-click="$event.stopPropagation()")
        div.modal-header
          h3
            i.bi.bi-list-check
            |  Review Item Baru ({{ modalReview.items.length }})
          button.modal-close(ng-click="closeReviewModal()") ×
        div.modal-body
          p.section-desc
            | Sistem auto-detect tebal dari nama item dan suggest group.
            | Anda bisa override pilihan group atau buat group baru.
          div.review-summary
            div.review-stat
              strong.stat-num {{ modalReview.items.length }}
              span.stat-label Total item baru
            div.review-stat.success
              strong.stat-num {{ countAutoSuggested() }}
              span.stat-label Auto-suggested
            div.review-stat.warning(ng-if="countNeedManual() > 0")
              strong.stat-num {{ countNeedManual() }}
              span.stat-label Perlu manual
          div.review-table-wrapper
            table.review-table
              thead
                tr
                  th(style="width:40%") NAMA ITEM
                  th(style="width:10%") BERAT
                  th(style="width:12%") TEBAL
                  th(style="width:30%") ASSIGN KE GROUP
                  th(style="width:60px")
              tbody
                tr(ng-repeat="it in modalReview.items" ng-class="{'row-skipped': it._skipped}")
                  td
                    span.it-name {{ it.i_name }}
                  td.text-right.mono {{ it.i_weight | number:2 }}
                  td.text-center
                    span.thickness-tag(ng-if="it.detected_thickness !== null") {{ it.detected_thickness }} mm
                    span.thickness-tag.unknown(ng-if="it.detected_thickness === null") tidak terdeteksi
                  td
                    select(ng-model="it._selectedGroupId" ng-disabled="it._skipped || it._createNew")
                      option(value="") -- Pilih group --
                      option(ng-repeat="g in modalReview.available_groups" value="{{ g.id }}") {{ g.thickness_label }}
                    div.create-new-option(ng-if="it.can_create_group")
                      label
                        input(type="checkbox" ng-model="it._createNew" ng-change="onCreateNewToggle(it)")
                        |  Buat group baru ({{ it.detected_thickness }} mm)
                  td.text-center
                    button.btn-icon-mini(ng-click="toggleSkip(it)" title="Skip")
                      i.bi(ng-class="it._skipped ? 'bi-arrow-counterclockwise' : 'bi-x-circle'")
        div.modal-actions
          button.btn-ghost(ng-click="closeReviewModal()") Batal
          button.btn-primary(
            ng-click="executeBatchConfirm()"
            ng-disabled="modalReview.executing || !canConfirm()")
            i.bi.bi-check-circle(ng-if="!modalReview.executing")
            i.bi.bi-arrow-clockwise.spinning(ng-if="modalReview.executing")
            |  Konfirmasi {{ countToConfirm() }} Item

    //- Modal: Post validation
    div.modal-overlay(ng-if="modalValidation" ng-click="closeValidationModal()")
      div.modal-card.modal-medium(ng-click="$event.stopPropagation()")
        div.modal-header
          h3
            i.bi.bi-shield-exclamation
            |  Validasi Sebelum Post to ERP
          button.modal-close(ng-click="closeValidationModal()") ×
        div.modal-body
          div(ng-if="modalValidation.blockers.length > 0")
            div.validation-section.danger
              h4
                i.bi.bi-x-octagon-fill
                |  TIDAK BISA POST
              div.validation-item.danger(ng-repeat="b in modalValidation.blockers")
                i.bi.bi-exclamation-triangle-fill
                div
                  strong {{ b.message }}
                  p.muted Item baru harus di-assign group dulu.
            div.validation-actions
              button.btn-primary(ng-click="closeValidationModal(); openReviewModal()")
                | Buka Review Item Baru
          div(ng-if="modalValidation.blockers.length === 0")
            div.validation-section.success
              i.bi.bi-check-circle-fill
              strong Siap di-post
            div.validation-section.warning(ng-if="modalValidation.warnings.length > 0")
              h4
                i.bi.bi-exclamation-circle-fill
                |  Peringatan
              div.validation-item.warning(ng-repeat="w in modalValidation.warnings")
                div
                  strong {{ w.message }}
                  ul(ng-if="w.groups && w.groups.length > 0")
                    li(ng-repeat="g in w.groups | limitTo:5") {{ g }}
                    li(ng-if="w.groups.length > 5") ...dan {{ w.groups.length - 5 }} lainnya
        div.modal-actions
          button.btn-ghost(ng-click="closeValidationModal()") Tutup
          button.btn-primary(
            ng-if="modalValidation.blockers.length === 0"
            ng-click="proceedToPost()")
            i.bi.bi-cloud-upload
            |  Lanjut Post to ERP
