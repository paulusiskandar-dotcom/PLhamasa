extends master

block content
  div.plm-wrapper(ng-class="{'sidebar-hidden': sidebarHidden}" ng-controller="priceListController")

    //- ── Sidebar ──────────────────────────────────────────────────────────────
    nav.sidebar
      div.sidebar-brand
        span.brand-icon ⬡
        span Price List Manager
      ul.sidebar-nav
        li.active
          a(href="/price-list")
            i.bi.bi-table
            span  Price List
        li
          a(href="/settings")
            i.bi.bi-gear
            span  Settings
        li
          a(href="/logout")
            i.bi.bi-box-arrow-left
            span  Logout

    //- ── Main Content ─────────────────────────────────────────────────────────
    main.main-content

      button.sidebar-toggle(ng-click="toggleSidebar()" aria-label="Toggle sidebar")
        i.bi.bi-list

      //- Header
      div.page-header
        div
          h2.page-title Price List
          p.page-sub Kelola dan export harga barang besi
        div.header-actions
          button.btn-outline(ng-click="exportTemplatePerKilo()" ng-disabled="isExportingTemplate")
            i.bi.bi-download
            |  Template Per Kilo
          label.btn-outline(for="import-file")
            i.bi.bi-upload
            |  Import Template
          input#import-file(type="file" accept=".xlsx" onchange="angular.element(this).scope().handleFileSelect(this.files); angular.element(this).scope().$apply()" style="display:none")

      //- ── Filter Panel ───────────────────────────────────────────────────────
      div.filter-panel
        div.filter-row
          div.filter-group
            label Kategori
            select.form-control(
              ng-model="filter.category"
              ng-options="c.name for c in categories track by c.id"
            )
              option(value="") Semua Kategori
          div.filter-group
            label Merek
            select.form-control(
              ng-model="filter.brand"
              ng-options="b.name for b in brands track by b.id"
            )
              option(value="") Semua Merek
          div.filter-group
            label Grade
            select.form-control(
              ng-model="filter.grade"
              ng-options="g.name for g in grades track by g.id"
            )
              option(value="") Semua Grade
          div.filter-group
            label Golongan
            select.form-control(ng-model="filter.group" ng-options="g.label for g in groupOptions track by g.id")
          div.filter-group
            label Nama Barang
            input.form-control(type="text" ng-model="filter.item_search_name" placeholder="Cari nama barang...")
          div.filter-group.filter-action
            button.btn-primary(ng-click="search()")
              i.bi.bi-search
              |  Cari

      //- ── Modifier Section (DI ATAS tabel) ───────────────────────────────────
      div.modifier-section(ng-if="items && items.length > 0")
        div.modifier-header
          span.modifier-title
            i.bi.bi-lightning-charge
            |  Pengubah Harga
        div.modifier-body
          //- Target checkboxes (dynamic per priceTypes)
          div.modifier-field
            label Target
            div.target-checks
              label.target-check-label(ng-repeat="pt in priceTypes")
                input(type="checkbox" ng-model="modifier.targets[pt.code]")
                span {{ pt.label }}
                span.target-group-tag(ng-if="isExtended")  {{ pt.group }}
          //- Quick-select (show group buttons only if extended)
          div.modifier-field
            label &nbsp;
            div.quick-select
              button.btn-qs(ng-click="selectAllTargets()") Semua
              button.btn-qs(ng-if="isExtended" ng-repeat="g in priceGroups" ng-click="selectGroupTargets(g)") {{ g }}
          div.modifier-field
            label Modifier
            select.form-control.modifier-select(ng-model="modifier.selected" ng-options="m.label for m in modifierOptions track by m.id")
          div.modifier-field
            label Nilai
            input.form-control.modifier-input(
              type="number"
              ng-model="modifier.value"
              placeholder="0"
              min="0"
            )
          div.modifier-field.modifier-action
            button.btn-generate(ng-click="generatePrices()")
              i.bi.bi-lightning-charge
              |  Generate Harga Baru

        //- Save & Export
        //- auto-save status indicator only
        div.sync-row(ng-if="syncState !== 'idle'")
          div.sync-indicator(ng-if="syncState === 'saving'")
            i.bi.bi-arrow-repeat.spin
            span  Auto-saving...
          div.sync-indicator.sync-ok(ng-if="syncState === 'saved'")
            i.bi.bi-check-circle
            span  Auto-saved

      //- ── Table ──────────────────────────────────────────────────────────────
      div.table-wrapper(ng-if="items !== null")

        //- Category Banner
        div.category-banner(ng-if="categoryInfo && items.length > 0")
          div.banner-left
            span.banner-cat {{ categoryInfo.cat_name }}
            span.banner-erp-date(ng-if="categoryInfo.erp_last_update")
              i.bi.bi-calendar3
              |  ERP: {{ categoryInfo.erp_last_update | plmDate }}
            span.banner-sync {{ syncSummary() }}
          div.banner-right
            div.banner-export(ng-if="categoryInfo.last_export")
              span Last Export: {{ categoryInfo.last_export.exported_at | plmDate }}
              span  · {{ categoryInfo.last_export.exporter_name }}
              span  · {{ categoryInfo.last_export.item_count }} items
            div.banner-export(ng-if="!categoryInfo.last_export")
              span.text-muted Belum pernah di-export
            button.btn-outline.btn-sm(ng-click="openHistoryModal()")
              i.bi.bi-clock-history
              |  Riwayat Export

        div.table-info(ng-if="items.length > 0")
          span {{ items.length }} barang ditemukan

        div.empty-state(ng-if="items.length === 0")
          i.bi.bi-inbox
          p Tidak ada barang ditemukan

        div.table-scroll(ng-if="items.length > 0")
          table.data-table

            //- ─ STANDARD header (2 price types: Cash, Kredit) ─
            thead(ng-if="!isExtended")
              tr
                th.th-check(rowspan="2")
                  input(type="checkbox" ng-model="selection.all" ng-change="toggleSelectAll()")
                th(rowspan="2" style="width:38px") No
                th.th-sortable(rowspan="2" ng-click="sortBy('name')")
                  | Nama Barang
                  i.bi.sort-icon(ng-class="sortIcon('name')" ng-class-active="sortActive('name')")
                th.th-sortable.text-right(rowspan="2" ng-click="sortBy('weight')")
                  | Berat
                  i.bi.sort-icon(ng-class="sortIcon('weight')" ng-class-active="sortActive('weight')")
                th.th-group(colspan="3") CASH
                th.th-group.th-group-alt(colspan="3") KREDIT
              tr
                th.th-sortable.text-right(ng-click="sortBy('cash_gudang')")
                  | /kg
                  i.bi.sort-icon(ng-class="sortIcon('cash_gudang')")
                th.th-new /kg Baru
                th.th-lbr /lbr
                th.th-sortable.text-right(ng-click="sortBy('kredit_gudang')")
                  | /kg
                  i.bi.sort-icon(ng-class="sortIcon('kredit_gudang')")
                th.th-new /kg Baru
                th.th-lbr /lbr

            //- ─ EXTENDED header (4 price types: Gudang & Pabrik) ─
            thead(ng-if="isExtended")
              tr
                th.th-check(rowspan="3")
                  input(type="checkbox" ng-model="selection.all" ng-change="toggleSelectAll()")
                th(rowspan="3" style="width:38px") No
                th.th-sortable(rowspan="3" ng-click="sortBy('name')")
                  | Nama Barang
                  i.bi.sort-icon(ng-class="sortIcon('name')")
                th.th-sortable.text-right(rowspan="3" ng-click="sortBy('weight')")
                  | Berat
                  i.bi.sort-icon(ng-class="sortIcon('weight')")
                th.th-group(colspan="6") GUDANG
                th.th-group.th-group-alt(colspan="6") PABRIK
              tr
                th.th-group-sub(colspan="3") Cash
                th.th-group-sub(colspan="3") Kredit
                th.th-group-sub(colspan="3") Cash
                th.th-group-sub(colspan="3") Kredit
              tr
                th.th-sortable.text-right(ng-click="sortBy('cash_gudang')")
                  | /kg
                  i.bi.sort-icon(ng-class="sortIcon('cash_gudang')")
                th.th-new /kg Baru
                th.th-lbr /lbr
                th.th-sortable.text-right(ng-click="sortBy('kredit_gudang')")
                  | /kg
                  i.bi.sort-icon(ng-class="sortIcon('kredit_gudang')")
                th.th-new /kg Baru
                th.th-lbr /lbr
                th.th-sortable.text-right(ng-click="sortBy('cash_pabrik')")
                  | /kg
                  i.bi.sort-icon(ng-class="sortIcon('cash_pabrik')")
                th.th-new /kg Baru
                th.th-lbr /lbr
                th.th-sortable.text-right(ng-click="sortBy('kredit_pabrik')")
                  | /kg
                  i.bi.sort-icon(ng-class="sortIcon('kredit_pabrik')")
                th.th-new /kg Baru
                th.th-lbr /lbr

            //- ─ TBODY (dynamic columns via ng-repeat-start/end) ─
            tbody
              tr(
                ng-repeat="item in items"
                ng-class="{'row-has-new': hasDrafts() && item.new && (item.new | json) !== '{}', 'row-just-edited': item.justEdited}"
              )
                td.td-check
                  input(type="checkbox" ng-model="item.checked" ng-change="onItemCheck()")
                td.text-muted {{ $index + 1 }}
                td
                  | {{ item.name }}
                  span.warn-badge(
                    ng-if="isSpotUpdate(item)"
                    title="Item ini update terakhir {{ item.erp_updated_at | plmDate }}, berbeda dari update massal kategori {{ catMaxUpdatedAt | plmDate }}"
                  ) ⚠
                td.mono.text-right {{ item.weight }}
                //- Per price-type: /kg lama | /kg baru (input, blur) | /lbr
                td.mono.text-right(ng-repeat-start="pt in priceTypes track by pt.code")
                  | {{ item.prices[pt.code].current | number }}
                td.td-new(ng-class="{'td-has-new': item.new[pt.code] != null}")
                  input.price-input(
                    type="text"
                    inputmode="numeric"
                    thousand-separator
                    ng-model="item.new[pt.code]"
                    ng-model-options="{ updateOn: 'blur', debounce: { blur: 0 } }"
                    ng-change="onManualOverride(item, pt)"
                    placeholder="—"
                  )
                td.mono.text-right.price-lbr(ng-repeat-end)
                  span(ng-if="item.new_unit[pt.code] != null") {{ item.new_unit[pt.code] | number:0 }}
                  span.price-unit-empty(ng-if="item.new_unit[pt.code] == null") —

      //- ── Action Bar ───────────────────────────────────────────────────────
      div.action-bar(ng-if="items && items.length > 0")
        div.action-bar-left
          div.sync-row(ng-if="syncState !== 'idle'")
            span.sync-indicator(ng-if="syncState === 'saving'")
              i.bi.bi-arrow-repeat.spin
              |  Auto-saving...
            span.sync-indicator.sync-ok(ng-if="syncState === 'saved'")
              i.bi.bi-check-circle
              |  Auto-saved
        div.action-bar-right
          button.btn-action-save(
            ng-click="saveAll()"
            ng-disabled="!hasChanges() || saveState === 'saving'"
            ng-if="hasChanges() || saveState === 'saving'"
          )
            i.bi(ng-class="{'bi-save': saveState !== 'saving', 'bi-hourglass-split': saveState === 'saving'}")
            span(ng-if="saveState !== 'saving'")  Simpan ({{ pendingChanges.length }})
            span(ng-if="saveState === 'saving'")  Menyimpan...
          button.btn-action-export(
            ng-click="doExportERP()"
            ng-disabled="hasChanges()"
            title="{{ hasChanges() ? 'Simpan dulu sebelum export' : 'Export ke format ERP' }}"
          )
            i.bi.bi-file-earmark-excel
            |  Export ERP
          button.btn-action-export(
            ng-click="doExportManual()"
            ng-disabled="hasChanges()"
            title="{{ hasChanges() ? 'Simpan dulu sebelum export' : 'Export manual' }}"
          )
            i.bi.bi-file-earmark-text
            |  Export Manual
          button.btn-action-print(disabled title="Fitur segera hadir")
            i.bi.bi-printer
            |  Print PDF

      //- ── History Modal ────────────────────────────────────────────────────
      div.modal-backdrop(ng-if="showHistoryModal" ng-click="closeHistoryModal()")
      div.modal-box(ng-if="showHistoryModal")
        div.modal-head
          span.modal-title
            i.bi.bi-clock-history
            |  Riwayat Export
          button.modal-close(ng-click="closeHistoryModal()") ×
        div.modal-body
          div.loading-state(ng-if="historyLoading")
            i.bi.bi-arrow-repeat.spin
            span  Memuat...
          table.data-table(ng-if="!historyLoading && exportHistory.length > 0")
            thead
              tr
                th Tanggal
                th Tipe
                th Jumlah
                th File
                th
            tbody
              tr(ng-repeat="h in exportHistory")
                td.mono {{ h.exported_at | plmDateTime }}
                td
                  span.badge-type(ng-class="'badge-' + h.export_type") {{ h.export_type | uppercase }}
                td {{ h.item_count }}
                td.mono.text-muted {{ h.file_name }}
                td
                  button.btn-outline.btn-sm(ng-click="downloadHistory(h.id)" ng-if="h.file_name")
                    i.bi.bi-download
          div.empty-state(ng-if="!historyLoading && exportHistory.length === 0")
            i.bi.bi-inbox
            p Belum ada history export
          div.modal-pagination(ng-if="exportHistory.length > 0")
            button.btn-outline.btn-sm(ng-click="historyPrev()" ng-disabled="historyOffset === 0")
              i.bi.bi-chevron-left
            span  Hal {{ historyPage() }}
            button.btn-outline.btn-sm(ng-click="historyNext()" ng-disabled="exportHistory.length < 20")
              i.bi.bi-chevron-right

      //- Toast
      div.toast-container(ng-if="toast.show")
        div.toast-msg(ng-class="'toast-' + toast.type")
          i.bi(ng-class="{'bi-check-circle': toast.type==='success', 'bi-exclamation-circle': toast.type==='danger', 'bi-info-circle': toast.type==='info', 'bi-exclamation-triangle': toast.type==='warning'}")
          |  {{ toast.message }}
