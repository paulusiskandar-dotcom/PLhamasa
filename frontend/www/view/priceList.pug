extends master

block content
  div.plm-wrapper(ng-class="{'sidebar-hidden': sidebarHidden}" ng-controller="priceListListController")

    //- Sidebar
    nav.sidebar
      div.sidebar-brand
        span.brand-icon ⬡
        span Price List Manager
      ul.sidebar-nav
        li.active
          a(href="/price-list")
            i.bi.bi-table
            span  Price List
        li
          a(href="/settings")
            i.bi.bi-gear
            span  Settings

      div.sidebar-user
        div.user-info
          i.bi.bi-person-circle.user-avatar
          div.user-meta
            div.user-name {{ currentUser.full_name || currentUser.username }}
            span.role-badge(ng-class="'role-' + currentUser.role") {{ currentUser.role | uppercase }}
        div.user-actions
          button.user-action-btn(ng-click="openChangePassword()")
            i.bi.bi-key
            |  Ubah Password
          a.user-action-btn(href="/logout")
            i.bi.bi-box-arrow-right
            |  Logout

    //- Main
    main.main-content

      button.sidebar-toggle(ng-click="toggleSidebar()" aria-label="Toggle sidebar")
        i.bi.bi-list

      div.page-header
        div
          h2.page-title Price List
          p.page-sub Riwayat semua price list per kategori

      //- Filter
      div.filter-bar
        div.filter-group
          label Kategori
          select.form-control(ng-model="filter.catId" ng-change="applyFilterSort()" ng-options="c.id as c.name for c in categories")
            option(value="") Semua Kategori
        div.filter-group
          label Status
          select.form-control(ng-model="filter.status" ng-change="applyFilterSort()")
            option(value="") Semua Status
            option(value="OPEN") OPEN (sedang draft)
            option(value="PUBLISHED") PUBLISHED (arsip)
        div.filter-group
          label Sort By
          select.form-control(ng-model="filter.sortBy" ng-change="applyFilterSort()")
            option(value="default") Status & Kategori (default)
            option(value="created_desc") Terbaru Dibuat
            option(value="updated_desc") Terbaru Diedit
            option(value="cat_name") Kategori A-Z

      //- Loading
      div.loading-state(ng-if="loading")
        i.bi.bi-arrow-repeat.spin
        span  Memuat...

      //- Empty state global
      div.empty-state(ng-if="!loading && groupedLists.length === 0")
        i.bi.bi-clipboard
        p Belum ada Price List
        button.btn-primary(ng-click="showStartModal()")
          i.bi.bi-plus
          |  Mulai Price List Baru

      //- Grouped by category
      div.category-group(ng-repeat="group in groupedLists")
        div.category-header(ng-if="!group.flat")
          h3 {{ group.cat_name }}
          button.btn-secondary.btn-sm(ng-if="!group.has_open" ng-click="startNew(group.cat_id, group.cat_name)")
            i.bi.bi-plus
            |  Mulai Baru

        div.pl-card(ng-repeat="pl in group.records" ng-class="'pl-' + pl.status.toLowerCase()")
          div.pl-header
            span.pl-revision \#{{ pl.revision_no | padNumber:3 }}
            span.pl-category(ng-if="group.flat") {{ pl.cat_name }}
            span.pl-status(ng-class="'status-' + pl.status.toLowerCase()") {{ pl.status }}
            span.pl-timestamp {{ pl.created_at | dateFormat }}
            span.lock-badge.lock-mine(ng-if="pl.locked_status === 'mine'")  🟢 Sedang Anda edit
            span.lock-badge.lock-other(ng-if="pl.locked_status === 'other_active'")  🟡 Diedit {{ pl.locked_by_name }}
            span.lock-badge.lock-stale(ng-if="pl.locked_status === 'other_idle'")  🟠 Idle ({{ pl.locked_by_name }})

          div.pl-body
            span(ng-if="pl.status === 'OPEN'")
              | {{ pl.item_count }} items
              span(ng-if="pl.last_log_at")  · edit terakhir {{ pl.last_log_at | timeAgo }}
            span(ng-if="pl.status === 'PUBLISHED'")
              | Posted oleh {{ pl.posted_by_name }} · {{ pl.posted_at | dateFormat }} · {{ pl.item_count }} items

          div.pl-actions
            button.btn-primary.btn-sm(ng-if="pl.status === 'OPEN' && pl.locked_status !== 'other_active'" ng-click="continueEdit(pl)")
              i.bi.bi-pencil
              |  {{ pl.locked_status === 'other_idle' ? 'Take Over & Edit' : 'Continue Edit' }}
            a.btn-secondary.btn-sm(ng-if="pl.status === 'PUBLISHED'" href="/view/{{ pl.id }}")
              i.bi.bi-eye
              |  Lihat Detail
            button.btn-ghost.btn-sm(ng-click="showLog(pl)")
              i.bi.bi-clock-history
              |  Log
            button.btn-ghost.btn-sm(ng-click="exportPdf(pl)")
              i.bi.bi-file-pdf
              |  PDF
            button.btn-ghost.btn-sm(ng-click="exportExcel(pl)")
              i.bi.bi-file-earmark-excel
              |  Excel

      //- Modal Start New
      div.modal-overlay(ng-if="modalStart")
        div.modal-card(ng-click="$event.stopPropagation()")
          h3 Mulai Price List Baru
          p Pilih kategori ERP:
          select.form-control(ng-model="modalStart.catId" ng-options="c.id as c.name for c in categoriesAvailable")
            option(value="") Pilih kategori...
          div.modal-actions
            button.btn-ghost(ng-click="modalStart = null") Batal
            button.btn-primary(ng-click="confirmStartNew()" ng-disabled="!modalStart.catId")
              i.bi.bi-check2
              |  Mulai

      //- Modal Detail (PUBLISHED)
      div.modal-overlay(ng-if="modalDetail" ng-click="modalDetail = null")
        div.modal-card.modal-large(ng-click="$event.stopPropagation()")
          div.modal-header
            div
              h3 {{ modalDetail.cat_name }} — \#{{ modalDetail.revision_no | padNumber:3 }}
              span.pl-status.status-published PUBLISHED
            button.modal-close(ng-click="modalDetail = null") ×
          div.modal-body
            p.detail-meta
              | Posted by {{ modalDetail.posted_by_name }} pada {{ modalDetail.posted_at | dateTimeFormat }}
            table.detail-table(ng-if="modalDetail.items && modalDetail.items.length > 0")
              thead
                tr
                  th ig_id
                  th pr_id
                  th Harga/kg
              tbody
                tr(ng-repeat="item in modalDetail.items")
                  td.mono {{ item.ig_id }}
                  td.mono {{ item.pr_id }}
                  td.mono.text-right {{ item.i_price | number:0 }}
          div.modal-actions
            button.btn-ghost(ng-click="exportPdf(modalDetail)") Export PDF
            button.btn-ghost(ng-click="exportExcel(modalDetail)") Export Excel
            button.btn-primary(ng-click="modalDetail = null") Tutup

      //- Modal Log
      div.modal-overlay(ng-if="modalLog" ng-click="closeLog()")
        div.modal-card.modal-large(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Log — {{ modalLog.cat_name }} \#{{ modalLog.revision_no | padNumber:3 }}
            button.modal-close(ng-click="closeLog()") ×
          div.modal-body
            div.loading-state(ng-if="modalLog.loading")
              i.bi.bi-arrow-repeat.spin
              span  Memuat...
            div.empty-state(ng-if="!modalLog.loading && modalLog.entries.length === 0")
              i.bi.bi-inbox
              p Belum ada perubahan dicatat
            table.log-table(ng-if="!modalLog.loading && modalLog.entries.length > 0")
              thead
                tr
                  th Waktu
                  th User
                  th ig_id
                  th pr_id
                  th Lama
                  th Baru
              tbody
                tr(ng-repeat="entry in modalLog.entries")
                  td.mono {{ entry.logged_at | dateTimeFormat }}
                  td {{ entry.user_name }}
                  td.mono {{ entry.ig_id }}
                  td.mono {{ entry.pr_id }}
                  td.mono.text-right {{ entry.old_price | number:0 }}
                  td.mono.text-right {{ entry.new_price | number:0 }}
          div.modal-actions
            button.btn-primary(ng-click="closeLog()") Tutup

      //- Modal PDF Template
      div.modal-overlay(ng-if="modalPdfTemplate" ng-click="closePdfTemplateModal()")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Pilih Template PDF
            button.modal-close(ng-click="closePdfTemplateModal()") ×
          div.modal-body
            div.empty-state(ng-if="!pdfTemplateOptions || pdfTemplateOptions.length === 0")
              i.bi.bi-file-earmark-pdf
              p Belum ada template PDF untuk kategori ini.
            div.tpl-list(ng-if="pdfTemplateOptions && pdfTemplateOptions.length > 0")
              button.tpl-option(ng-repeat="tpl in pdfTemplateOptions" ng-click="exportPdfWithTemplate(tpl.key)")
                strong {{ tpl.name }}
                small {{ tpl.description }}
          div.modal-actions
            button.btn-ghost(ng-click="closePdfTemplateModal()") Tutup

      //- Toast
      div.toast-container(ng-if="toast.show")
        div.toast-msg(ng-class="'toast-' + toast.type")
          | {{ toast.message }}
