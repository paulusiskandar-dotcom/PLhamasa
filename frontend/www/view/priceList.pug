extends master

block content
  div.plm-wrapper(ng-class="{'sidebar-hidden': sidebarHidden}" ng-controller="priceListListController")

    //- Sidebar
    nav.sidebar
      div.sidebar-brand
        span.brand-icon ⬡
        span Price List Manager
      ul.sidebar-nav
        li.active
          a(href="/price-list")
            i.bi.bi-table
            span  Price List
        li
          a(href="/published-history")
            i.bi.bi-clock-history
            span  Published History
        li
          a(href="/settings")
            i.bi.bi-gear
            span  Settings

      div.sidebar-user
        div.user-info
          i.bi.bi-person-circle.user-avatar
          div.user-meta
            div.user-name {{ currentUser.full_name || currentUser.username }}
            span.role-badge(ng-class="'role-' + currentUser.role") {{ currentUser.role | uppercase }}
        div.user-actions
          button.user-action-btn(ng-click="openChangePassword()")
            i.bi.bi-key
            |  Ubah Password
          a.user-action-btn(href="/logout")
            i.bi.bi-box-arrow-right
            |  Logout

    //- Main
    main.main-content

      button.sidebar-toggle(ng-click="toggleSidebar()" aria-label="Toggle sidebar")
        i.bi.bi-list

      //- Header
      div.pl-page-header
        div.pl-page-header-left
          h2.page-title Price List
          p.page-sub {{ aktiveCategoryCount }} kategori aktif · {{ notCreatedCount }} kategori belum dibuat
        button.btn-create-new(ng-click="showStartModal()")
          i.bi.bi-plus
          |  Buat baru

      //- Filter
      div.filter-bar
        div.filter-row-1
          div.filter-group
            label Kategori
            select.form-control(ng-model="filter.catId" ng-change="applyFilterSort()" ng-options="c.id as c.name for c in categories")
              option(value="") Semua Kategori
          div.filter-group
            label Status
            select.form-control(ng-model="filter.status" ng-change="applyFilterSort()")
              option(value="") Semua Status
              option(value="OPEN") OPEN
              option(value="PUBLISHED") PUBLISHED
          div.filter-group
            label Sort By
            select.form-control(ng-model="filter.sortBy" ng-change="applyFilterSort()")
              option(value="default") Default
              option(value="created_desc") Terbaru Dibuat
              option(value="updated_desc") Terbaru Diedit
              option(value="cat_name") Kategori A-Z
        div.quick-filter
          div.quick-filter-label Quick filter
          div.quick-filter-grid
            button.pill(
              ng-repeat="pill in categoryPills track by pill.catId"
              ng-class="{'pill-active': filter.catId === pill.catId, 'pill-inactive': filter.catId !== pill.catId && pill.hasData, 'pill-disabled': !pill.hasData}"
              ng-click="togglePill(pill.catId)"
              ng-disabled="!pill.hasData"
            ) {{ pill.name }}

      //- Loading
      div.loading-state(ng-if="loading")
        i.bi.bi-arrow-repeat.spin
        span  Memuat...

      //- Empty state
      div.empty-state(ng-if="!loading && groupedLists.length === 0")
        i.bi.bi-clipboard
        p Belum ada Price List
        button.btn-primary(ng-click="showStartModal()")
          i.bi.bi-plus
          |  Mulai Price List Baru

      //- Category grid
      div.category-grid(ng-if="!loading && groupedLists.length > 0")
        div.pl-card-v2(ng-repeat="group in groupedLists track by group.cat_id")

          div.pl-card-header {{ group.cat_name }}

          //- OPEN section
          div(ng-if="group.open")
            div.pl-revision-line
              span.pl-revision \#{{ group.open.revision_no | padNumber:3 }}
              span.pl-status-open OPEN
              span.pl-timestamp {{ group.open.created_at | dateFormat }}
              span.lock-badge.lock-mine(ng-if="group.open.locked_status === 'mine'")  🟢 Anda
              span.lock-badge.lock-other(ng-if="group.open.locked_status === 'other_active'")  🟡 {{ group.open.locked_by_name }}
              span.lock-badge.lock-stale(ng-if="group.open.locked_status === 'other_idle'")  🟠 Idle
            div.pl-meta
              | {{ group.open.item_count }} items
              span(ng-if="group.open.editedAgoStr")  · {{ group.open.editedAgoStr }}
            div.pl-action-row
              button.btn-primary.btn-sm(
                ng-if="group.open.locked_status !== 'other_active'"
                ng-click="continueEdit(group.open)"
              ) Edit
              span.btn-editing-placeholder(ng-if="group.open.locked_status === 'other_active'") Sedang diedit
              button.btn-ghost.btn-sm(ng-click="showLog(group.open)") Log
              button.btn-ghost.btn-sm(ng-click="exportPdf(group.open)") PDF
              button.btn-ghost.btn-sm(ng-click="exportExcel(group.open)") Excel

          //- Published collapsible footer
          div.pl-collapsible

            div(ng-if="group.publishedLatest")
              button.pl-collapsible-toggle(ng-click="togglePublished(group.cat_id)")
                i.bi(ng-class="expandedPublished[group.cat_id] ? 'bi-chevron-up' : 'bi-chevron-down'")
                span  {{ expandedPublished[group.cat_id] ? 'Sembunyikan' : 'Lihat published terakhir' }}
              div.pl-collapsible-content(ng-if="expandedPublished[group.cat_id]")
                div.pl-revision-line
                  span.pl-revision \#{{ group.publishedLatest.revision_no | padNumber:3 }}
                  span.pl-status-published PUBLISHED
                  span.pl-timestamp {{ group.publishedLatest.posted_at | dateFormat }}
                div.pl-meta(ng-if="group.publishedLatest.posted_by_name || group.publishedLatest.item_count")
                  span(ng-if="group.publishedLatest.posted_by_name") Posted oleh {{ group.publishedLatest.posted_by_name }}
                  span(ng-if="group.publishedLatest.posted_by_name && group.publishedLatest.item_count")  ·
                  span(ng-if="group.publishedLatest.item_count") {{ group.publishedLatest.item_count }} items
                div.pl-action-row
                  button.btn-primary.btn-sm(ng-click="showDetail(group.publishedLatest)") Detail
                  button.btn-ghost.btn-sm(ng-click="showLog(group.publishedLatest)") Log
                  button.btn-ghost.btn-sm(ng-click="exportPdf(group.publishedLatest)") PDF
                  button.btn-ghost.btn-sm(ng-click="exportExcel(group.publishedLatest)") Excel

            div.pl-no-published(ng-if="!group.publishedLatest") Belum pernah dipublish

      //- Modal Start New
      div.modal-overlay(ng-if="modalStart" ng-click="closeStartModal()")
        div.modal-card(ng-click="$event.stopPropagation()")
          h3 Mulai Price List Baru
          p Pilih kategori ERP:
          select.form-control(ng-model="modalStart.catId" ng-options="c.id as c.name for c in categoriesAvailable")
            option(value="") Pilih kategori...
          div.modal-actions
            button.btn-ghost(ng-click="closeStartModal()") Batal
            button.btn-primary(ng-click="confirmStartNew()" ng-disabled="!modalStart.catId")
              i.bi.bi-check2
              |  Mulai

      //- Modal Detail (PUBLISHED)
      div.modal-overlay(ng-if="modalDetail" ng-click="modalDetail = null")
        div.modal-card.modal-large(ng-click="$event.stopPropagation()")
          div.modal-header
            div
              h3 {{ modalDetail.cat_name }} — \#{{ modalDetail.revision_no | padNumber:3 }}
              span.pl-status.status-published PUBLISHED
            button.modal-close(ng-click="modalDetail = null") ×
          div.modal-body
            p.detail-meta
              | Posted by {{ modalDetail.posted_by_name }} pada {{ modalDetail.posted_at | dateTimeFormat }}
            table.detail-table(ng-if="modalDetail.items && modalDetail.items.length > 0")
              thead
                tr
                  th ig_id
                  th pr_id
                  th Harga/kg
              tbody
                tr(ng-repeat="item in modalDetail.items")
                  td.mono {{ item.ig_id }}
                  td.mono {{ item.pr_id }}
                  td.mono.text-right {{ item.i_price | number:0 }}
          div.modal-actions
            button.btn-ghost(ng-click="exportPdf(modalDetail)") Export PDF
            button.btn-ghost(ng-click="exportExcel(modalDetail)") Export Excel
            button.btn-primary(ng-click="modalDetail = null") Tutup

      //- Modal Log
      div.modal-overlay(ng-if="modalLog" ng-click="closeLog()")
        div.modal-card.modal-large(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Log — {{ modalLog.cat_name }} \#{{ modalLog.revision_no | padNumber:3 }}
            button.modal-close(ng-click="closeLog()") ×
          div.modal-body
            div.loading-state(ng-if="modalLog.loading")
              i.bi.bi-arrow-repeat.spin
              span  Memuat...
            div.empty-state(ng-if="!modalLog.loading && modalLog.entries.length === 0")
              i.bi.bi-inbox
              p Belum ada perubahan dicatat
            table.log-table(ng-if="!modalLog.loading && modalLog.entries.length > 0")
              thead
                tr
                  th Waktu
                  th User
                  th ig_id
                  th pr_id
                  th Lama
                  th Baru
              tbody
                tr(ng-repeat="entry in modalLog.entries")
                  td.mono {{ entry.logged_at | dateTimeFormat }}
                  td {{ entry.user_name }}
                  td.mono {{ entry.ig_id }}
                  td.mono {{ entry.pr_id }}
                  td.mono.text-right {{ entry.old_price | number:0 }}
                  td.mono.text-right {{ entry.new_price | number:0 }}
          div.modal-actions
            button.btn-primary(ng-click="closeLog()") Tutup

      //- Modal PDF Template
      div.modal-overlay(ng-if="modalPdfTemplate" ng-click="closePdfTemplateModal()")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Pilih Template PDF
            button.modal-close(ng-click="closePdfTemplateModal()") ×
          div.modal-body
            div.empty-state(ng-if="!pdfTemplateOptions || pdfTemplateOptions.length === 0")
              i.bi.bi-file-earmark-pdf
              p Belum ada template PDF untuk kategori ini.
            div.tpl-list(ng-if="pdfTemplateOptions && pdfTemplateOptions.length > 0")
              button.tpl-option(ng-repeat="tpl in pdfTemplateOptions" ng-click="exportPdfWithTemplate(tpl.key)")
                strong {{ tpl.name }}
                small {{ tpl.description }}
          div.modal-actions
            button.btn-ghost(ng-click="closePdfTemplateModal()") Tutup

      //- Toast
      div.toast-container(ng-if="toast.show")
        div.toast-msg(ng-class="'toast-' + toast.type")
          | {{ toast.message }}
