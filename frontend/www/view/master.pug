doctype html
html(lang="id")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= page.title

    //- Google Fonts
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet")

    //- Bootstrap
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    //- Bootstrap Icons
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")

    link(rel="stylesheet" href="/css/main.css")

    script.
      var api = { url: "!{apiUrl}" };

  body(ng-app="plmApp" ng-controller="userController")

    //- Global toast (from userController)
    div.global-toast-container(ng-if="globalToast.show")
      div.toast-notification(ng-class="'toast-' + globalToast.type") {{ globalToast.message }}

    //- Change Password Modal (global — accessible from any page)
    div.modal-overlay(ng-if="modalChangePwd" ng-click="closeChangePassword()")
      div.modal-card(ng-click="$event.stopPropagation()")
        div.modal-header
          h3 Ubah Password
          button.modal-close(ng-click="closeChangePassword()") ×
        div.modal-body
          div.form-group
            label Password Lama
            input.form-control(type="password" ng-model="modalChangePwd.old_password" placeholder="Password saat ini")
          div.form-group
            label Password Baru
            input.form-control(type="password" ng-model="modalChangePwd.new_password" placeholder="Minimal 8 karakter")
          div.form-group
            label Konfirmasi Password Baru
            input.form-control(type="password" ng-model="modalChangePwd.confirm_password" placeholder="Ulangi password baru")
        div.modal-actions
          button.btn-ghost(ng-click="closeChangePassword()") Batal
          button.btn-primary(ng-click="executeChangePwd()") Ubah Password

    block content

    //- Vendor JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.3/angular.min.js")
    script(src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js")

    //- App JS
    script(src="/js/app.js")

    //- Global: always load user service + controller
    script(src="/js/services/user.js")
    script(src="/js/controller/user/userController.js")

    if page.data
      each svc in page.data.services
        script(src=svc)
      if page.data.controller
        script(src=page.data.controller)
