extends master

block content
  div.plm-wrapper(ng-class="{'sidebar-hidden': sidebarHidden}" ng-controller="settingsController")

    nav.sidebar
      div.sidebar-brand
        span.brand-icon ⬡
        span Price List Manager
      ul.sidebar-nav
        li
          a(href="/price-list")
            i.bi.bi-table
            span  Price List
        li.active
          a(href="/settings")
            i.bi.bi-gear
            span  Settings

      div.sidebar-user
        div.user-info
          i.bi.bi-person-circle.user-avatar
          div.user-meta
            div.user-name {{ currentUser.full_name || currentUser.username }}
            span.role-badge(ng-class="'role-' + currentUser.role") {{ currentUser.role | uppercase }}
        div.user-actions
          button.user-action-btn(ng-click="openChangePassword()")
            i.bi.bi-key
            |  Ubah Password
          a.user-action-btn(href="/logout")
            i.bi.bi-box-arrow-right
            |  Logout

    main.main-content

      button.sidebar-toggle(ng-click="toggleSidebar()" aria-label="Toggle sidebar")
        i.bi.bi-list

      div.page-header
        div
          h2.page-title Settings
          p.page-sub Konfigurasi aplikasi

      div.toast-container(ng-if="toast.show")
        div.toast-msg(ng-class="'toast-' + toast.type") {{ toast.message }}

      //- Section 1: Extended Categories
      div.settings-section
        div.section-header
          i.bi.bi-tags
          h3 Kategori dengan Harga Pabrik
        div.section-body
          p.section-desc
            | Kategori di bawah ini akan tampil dengan kolom tambahan:
            |  #[strong Cash Pabrik] &amp; #[strong Kredit Pabrik].
            br
            | Kategori lain hanya menampilkan Cash Gudang &amp; Kredit Gudang.
          div.checkbox-grid(ng-if="categories.length > 0")
            label.checkbox-item(ng-repeat="cat in categories")
              input(type="checkbox" ng-model="extendedSelection[cat.id]" ng-change="markExtendedDirty()")
              span {{ cat.name }}
          div.empty-mini(ng-if="categories.length === 0")
            | Memuat kategori...
        div.section-footer
          button.btn-ghost(ng-click="resetExtended()" ng-disabled="!extendedDirty") Batal
          button.btn-primary(ng-click="saveExtended()" ng-disabled="!extendedDirty")
            i.bi.bi-save
            |  Simpan

      //- Section 2: Subcategory
      div.settings-section
        div.section-header
          i.bi.bi-collection
          h3 Subkategori
        div.section-body
          p.section-desc
            | Buat subkategori sebagai filter tambahan saat edit Price List.
            | 1 item hanya bisa masuk ke 1 subkategori per kategori.
          div.subcat-controls
            label Pilih Kategori
            select.form-control(ng-model="subcatFilter" ng-change="loadSubcategories()" ng-options="c.id as c.name for c in categories")
              option(value="") Pilih kategori...
          div(ng-if="subcatFilter")
            div.subcat-empty(ng-if="subcategories.length === 0") Belum ada subkategori untuk kategori ini.
            div.subcat-card(ng-repeat="sub in subcategories")
              div.subcat-info
                strong {{ sub.name }}
                span.item-count {{ sub.item_count || 0 }} items
              div.subcat-actions
                button.btn-ghost.btn-sm(ng-click="manageSubcatItems(sub)")
                  i.bi.bi-list-check
                  |  Items
                button.btn-ghost.btn-sm(ng-click="renameSubcat(sub)")
                  i.bi.bi-pencil
                button.btn-ghost.btn-sm.btn-danger(ng-click="deleteSubcat(sub)")
                  i.bi.bi-trash
            div.subcat-add
              button.btn-secondary(ng-click="showAddSubcat()" ng-disabled="!subcatFilter")
                i.bi.bi-plus-lg
                |  Tambah Subkategori

      //- Section 3: PDF Template — Custom Field Values
      div.settings-section
        div.section-header
          i.bi.bi-file-earmark-pdf
          h3 Template PDF — Custom Field
        div.section-body
          p.section-desc
            | Isi data custom per item untuk setiap template PDF
            | (contoh: diameter dalam inch / mm).
            | Nilai tersimpan otomatis saat blur.
          div.subcat-controls
            label Pilih Template
            select.form-control(ng-model="pdfTplKey" ng-change="loadPdfTpl()" ng-options="t.key as t.name + ' (' + t.cat_name + ')' for t in pdfTemplates")
              option(value="") Pilih template...
          div(ng-if="pdfTplData")
            p.detail-meta(style="margin-top:14px")
              | {{ pdfTplData.template.description }}
            table.pdf-field-table
              thead
                tr
                  th(style="min-width:260px") Nama Barang
                  th(ng-repeat="f in pdfTplData.template.custom_fields") {{ f.label }}
              tbody
                tr(ng-repeat="item in pdfTplData.items")
                  td.pdf-item-name {{ item.name }}
                  td(ng-repeat="f in pdfTplData.template.custom_fields")
                    input.form-control.pdf-field-input(
                      type="text"
                      ng-model="item.custom_values[f.key]"
                      ng-change="markPdfDirty()"
                      placeholder="—"
                    )
            div.pdf-save-bar
              span.pdf-save-status(ng-if="pdfTplDirty")
                i.bi.bi-exclamation-circle
                |  Ada perubahan belum disimpan
              span.pdf-save-status.saved(ng-if="!pdfTplDirty && pdfTplLastSaved")
                i.bi.bi-check-circle
                |  Tersimpan {{ pdfTplLastSaved | timeAgo }}
              button.btn-primary(ng-click="savePdfTplAll()" ng-disabled="!pdfTplDirty || pdfTplSaving")
                i.bi.bi-save(ng-if="!pdfTplSaving")
                i.bi.bi-arrow-clockwise.spinning(ng-if="pdfTplSaving")
                |  {{ pdfTplSaving ? 'Menyimpan...' : 'Simpan Semua' }}

      //- Section 4: Blacklist Item
      div.settings-section
        div.section-header
          i.bi.bi-slash-circle
          h3 Blacklist Item
        div.section-body
          p.section-desc
            | Item yang di-blacklist tidak akan muncul di rekaman price list baru,
            | edit OPEN, export Excel, export PDF, atau push ke ERP.
            | Rekaman PUBLISHED (arsip) tidak terpengaruh.
          div.bl-tabs
            button.bl-tab(ng-class="{active: blTab === 'add'}" ng-click="blTab = 'add'") Tambah ke Blacklist
            button.bl-tab(ng-class="{active: blTab === 'list'}" ng-click="blTab = 'list'; loadBlacklist()")
              | Daftar Blacklist
              span.bl-count(ng-if="blacklistData.length") {{ blacklistData.length }}

          div.bl-panel(ng-if="blTab === 'add'")
            div.bl-filters
              select.form-control(ng-model="blFilter.catId" ng-change="searchBlItems()" ng-options="c.id as c.name for c in categories")
                option(value="") Pilih kategori dulu...
              input.form-control(type="text" ng-model="blFilter.search" ng-change="searchBlItemsDebounced()" placeholder="Cari nama barang..." ng-disabled="!blFilter.catId")
            div.bl-items-wrap(ng-if="blAvailableItems.length")
              div.bl-actions-top
                label.bl-checkbox-all
                  input(type="checkbox" ng-model="blSelection.all" ng-change="toggleBlSelectAll()")
                  | Pilih semua ({{ blAvailableItems.length }})
                span.bl-selected-count(ng-if="blSelectedCount() > 0") {{ blSelectedCount() }} dipilih
              table.bl-table
                thead
                  tr
                    th(style="width:40px")
                    th Nama Barang
                    th(style="width:110px") Merek
                    th(style="width:80px") Grade
                    th(style="width:60px") Unit
                tbody
                  tr(ng-repeat="item in blAvailableItems")
                    td
                      input(type="checkbox" ng-model="item._selected" ng-change="updateBlSelectionAll()")
                    td.bl-item-name {{ item.i_name }}
                    td {{ item.i_brand || '-' }}
                    td {{ item.grade || '-' }}
                    td {{ item.un_name || '-' }}
              div.bl-actions-bottom(ng-if="blSelectedCount() > 0")
                button.btn-primary(ng-click="confirmAddBlacklist()")
                  i.bi.bi-slash-circle
                  |  Tambah ke Blacklist ({{ blSelectedCount() }} item)
            div.empty-state(ng-if="blFilter.catId && blAvailableItems.length === 0") Tidak ada item ditemukan
            div.empty-state(ng-if="!blFilter.catId") Pilih kategori untuk mulai

          div.bl-panel(ng-if="blTab === 'list'")
            div.empty-state(ng-if="blacklistData.length === 0") Belum ada item di blacklist
            table.bl-table(ng-if="blacklistData.length > 0")
              thead
                tr
                  th Nama Barang
                  th(style="width:120px") Kategori
                  th Alasan
                  th(style="width:90px") Oleh
                  th(style="width:130px") Kapan
                  th(style="width:90px")
              tbody
                tr(ng-repeat="b in blacklistData")
                  td.bl-item-name {{ b.i_name }}
                  td {{ b.cat_name }}
                  td.bl-reason {{ b.reason || '-' }}
                  td {{ b.blacklisted_by_name }}
                  td {{ b.blacklisted_at | dateTimeFormat }}
                  td
                    button.btn-ghost.btn-sm(ng-click="confirmRemoveBl(b)")
                      i.bi.bi-trash
                      |  Hapus

      //- Modal: Tambah Blacklist
      div.modal-overlay(ng-if="modalAddBl" ng-click="modalAddBl = null")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Tambah ke Blacklist
            button.modal-close(ng-click="modalAddBl = null") ×
          div.modal-body
            p {{ modalAddBl.count }} item akan di-blacklist:
            ul.bl-modal-list
              li(ng-repeat="item in modalAddBl.items | limitTo:5") {{ item.i_name }}
              li(ng-if="modalAddBl.items.length > 5")
                em ...dan {{ modalAddBl.items.length - 5 }} lainnya
            div.form-group(style="margin-top:14px")
              label Alasan (opsional)
              textarea.form-control(ng-model="modalAddBl.reason" rows="2" placeholder="Misal: Sudah discontinue")
          div.modal-actions
            button.btn-ghost(ng-click="modalAddBl = null") Batal
            button.btn-primary(ng-click="executeAddBlacklist()")
              | Konfirmasi Blacklist

      //- Modal: Hapus Blacklist
      div.modal-overlay(ng-if="modalRemoveBl" ng-click="modalRemoveBl = null")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Hapus dari Blacklist
            button.modal-close(ng-click="modalRemoveBl = null") ×
          div.modal-body
            p Item ini akan kembali muncul di sistem.
            p
              strong {{ modalRemoveBl.i_name }}
            p.bl-warning Item akan tersedia di rekaman price list baru, edit OPEN, export, dan push ERP.
          div.modal-actions
            button.btn-ghost(ng-click="modalRemoveBl = null") Batal
            button.btn-primary(ng-click="executeRemoveBlacklist()") Hapus dari Blacklist

      //- Section 5: ERP Target (superadmin only)
      div.settings-section(ng-if="isSuperadmin")
        div.section-header
          i.bi.bi-database
          h3 Target Database ERP
          span.role-badge Superadmin only
        div.section-body
          p.section-desc
            | Konfigurasi database ERP target untuk Post to ERP.
            | Hanya 1 target yang bisa aktif pada satu waktu.
          div.erp-target-list
            div.erp-empty(ng-if="erpTargets.length === 0") Belum ada ERP target.
            div.erp-card(ng-repeat="erp in erpTargets" ng-class="{'erp-active': erp.is_active}")
              div.erp-info
                div.erp-name
                  strong {{ erp.name }}
                  span.active-badge(ng-if="erp.is_active") AKTIF
                div.erp-host {{ erp.db_user }}@{{ erp.host }}:{{ erp.port }}/{{ erp.db_name }}
                div.erp-note(ng-if="erp.note") {{ erp.note }}
              div.erp-actions
                button.btn-ghost.btn-sm(ng-if="!erp.is_active" ng-click="activateErp(erp)")
                  i.bi.bi-toggle-on
                  |  Aktifkan
                button.btn-ghost.btn-sm(ng-click="testErp(erp)")
                  i.bi.bi-plug
                  |  Test
                button.btn-ghost.btn-sm(ng-click="editErp(erp)")
                  i.bi.bi-pencil
                button.btn-ghost.btn-sm.btn-danger(ng-click="deleteErp(erp)" ng-disabled="erp.is_active")
                  i.bi.bi-trash
          div.erp-add
            button.btn-secondary(ng-click="showAddErp()")
              i.bi.bi-plus-lg
              |  Tambah ERP Target

      //- Modal: Add/Edit Subcategory
      div.modal-overlay(ng-if="modalSubcat" ng-click="modalSubcat = null")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 {{ modalSubcat.editing ? 'Edit' : 'Tambah' }} Subkategori
          div.modal-body
            div.form-group
              label Nama Subkategori
              input.form-control(type="text" ng-model="modalSubcat.name" placeholder="Contoh: Diameter Kecil" autofocus)
          div.modal-actions
            button.btn-ghost(ng-click="modalSubcat = null") Batal
            button.btn-primary(ng-click="saveSubcat()" ng-disabled="!modalSubcat.name") Simpan

      //- Modal: Manage Subcategory Items
      div.modal-overlay(ng-if="modalSubcatItems" ng-click="modalSubcatItems = null")
        div.modal-card.modal-large(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Assign Items — {{ modalSubcatItems.subcat.name }}
            button.modal-close(ng-click="modalSubcatItems = null") ×
          div.modal-body
            p.section-desc Centang item yang masuk ke subkategori ini. Item yang sudah di-assign ke subkategori lain ditampilkan tapi tidak bisa dipilih.
            div.search-box
              i.bi.bi-search
              input(type="text" ng-model="modalSubcatItems.search" placeholder="Cari nama barang...")
            div.items-checklist
              div.loading-state(ng-if="modalSubcatItems.loading")
                span Memuat...
              label.checkbox-item(
                ng-repeat="item in modalSubcatItems.items | filter:{name: modalSubcatItems.search}"
                ng-class="{'item-disabled': item.assignedTo && item.assignedTo !== modalSubcatItems.subcat.id}"
              )
                input(
                  type="checkbox"
                  ng-model="modalSubcatItems.checked[item.ig_id]"
                  ng-disabled="item.assignedTo && item.assignedTo !== modalSubcatItems.subcat.id"
                )
                span
                  | {{ item.name }}
                  small.assigned-info(ng-if="item.assignedTo && item.assignedTo !== modalSubcatItems.subcat.id")
                    |  (di "{{ item.assignedToName }}")
          div.modal-actions
            button.btn-ghost(ng-click="modalSubcatItems = null") Tutup
            button.btn-primary(ng-click="saveSubcatItems()") Simpan Assignment

      //- Modal: Add/Edit ERP Target
      div.modal-overlay(ng-if="modalErp" ng-click="modalErp = null")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 {{ modalErp.editing ? 'Edit' : 'Tambah' }} ERP Target
          div.modal-body
            div.form-group
              label Nama *
              input.form-control(type="text" ng-model="modalErp.data.name" placeholder="Contoh: Production")
            div.form-group
              label Host *
              input.form-control(type="text" ng-model="modalErp.data.host" placeholder="192.168.1.100")
            div.form-row
              div.form-group
                label Port
                input.form-control(type="number" ng-model="modalErp.data.port")
              div.form-group
                label Database *
                input.form-control(type="text" ng-model="modalErp.data.db_name")
            div.form-row
              div.form-group
                label Username *
                input.form-control(type="text" ng-model="modalErp.data.db_user")
              div.form-group
                label Password
                input.form-control(type="password" ng-model="modalErp.data.db_password" placeholder="{{ modalErp.editing ? '(kosong = tidak diubah)' : '' }}")
            div.form-group
              label Catatan
              textarea.form-control(ng-model="modalErp.data.note" rows="2" placeholder="Opsional")
            div.test-result(ng-if="modalErp.testResult")
              div.test-success(ng-if="modalErp.testResult.success")
                i.bi.bi-check-circle-fill
                |  Connect berhasil. {{ modalErp.testResult.version }}
              div.test-fail(ng-if="!modalErp.testResult.success")
                i.bi.bi-x-circle-fill
                |  {{ modalErp.testResult.error }}
          div.modal-actions
            button.btn-ghost(ng-click="modalErp = null") Batal
            button.btn-ghost(ng-click="testErpModal()" ng-disabled="!modalErp.data.host || !modalErp.data.db_name")
              i.bi.bi-plug
              |  Test
            button.btn-primary(ng-click="saveErp()") Simpan

      //- Section 6: User Management (superadmin only)
      div.settings-section(ng-if="isSuperadmin")
        div.section-header
          i.bi.bi-people
          h3 User Management
          span.role-badge Superadmin only
        div.section-body
          p.section-desc Kelola user yang bisa akses PLhamasa.
          div.um-actions-top
            button.btn-primary(ng-click="openAddUser()")
              i.bi.bi-plus-circle
              |  Tambah User
          table.um-table
            thead
              tr
                th Username
                th Nama Lengkap
                th(style="width:120px") Role
                th(style="width:150px") Dibuat
                th(style="width:120px") Aksi
            tbody
              tr(ng-repeat="u in usersList")
                td.um-username
                  strong {{ u.username }}
                td {{ u.full_name }}
                td
                  span.role-badge(ng-class="'role-' + u.role") {{ u.role | uppercase }}
                td.um-date {{ u.created_at | dateTimeFormat }}
                td
                  button.btn-ghost.btn-sm(ng-click="openEditUser(u)" title="Edit")
                    i.bi.bi-pencil
                  button.btn-ghost.btn-sm(ng-click="openResetPwd(u)" title="Reset Password")
                    i.bi.bi-key
                  button.btn-ghost.btn-sm.btn-danger(ng-click="confirmDeleteUser(u)" ng-disabled="u.id === currentUser.id" title="Hapus")
                    i.bi.bi-trash

      //- Modal: Tambah User
      div.modal-overlay(ng-if="modalAddUser" ng-click="closeAddUser()")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Tambah User Baru
            button.modal-close(ng-click="closeAddUser()") ×
          div.modal-body
            div.form-group
              label Username
              input.form-control(type="text" ng-model="modalAddUser.username" placeholder="3-50 karakter, huruf/angka/_/.")
            div.form-group
              label Nama Lengkap
              input.form-control(type="text" ng-model="modalAddUser.full_name")
            div.form-group
              label Password
              input.form-control(type="password" ng-model="modalAddUser.password" placeholder="Minimal 8 karakter")
            div.form-group
              label Role
              select.form-control(ng-model="modalAddUser.role")
                option(value="user") User
                option(value="superadmin") Superadmin
          div.modal-actions
            button.btn-ghost(ng-click="closeAddUser()") Batal
            button.btn-primary(ng-click="executeAddUser()") Tambah

      //- Modal: Edit User
      div.modal-overlay(ng-if="modalEditUser" ng-click="closeEditUser()")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Edit User: {{ modalEditUser.username }}
            button.modal-close(ng-click="closeEditUser()") ×
          div.modal-body
            div.form-group
              label Nama Lengkap
              input.form-control(type="text" ng-model="modalEditUser.full_name")
            div.form-group
              label Role
              select.form-control(ng-model="modalEditUser.role" ng-disabled="modalEditUser.id === currentUser.id")
                option(value="user") User
                option(value="superadmin") Superadmin
              small.form-hint(ng-if="modalEditUser.id === currentUser.id") Tidak bisa ubah role akun sendiri
          div.modal-actions
            button.btn-ghost(ng-click="closeEditUser()") Batal
            button.btn-primary(ng-click="executeEditUser()") Simpan

      //- Modal: Reset Password
      div.modal-overlay(ng-if="modalResetPwd" ng-click="closeResetPwd()")
        div.modal-card(ng-click="$event.stopPropagation()")
          div.modal-header
            h3 Reset Password: {{ modalResetPwd.user.username }}
            button.modal-close(ng-click="closeResetPwd()") ×
          div.modal-body
            p.section-desc User akan menggunakan password baru ini saat login berikutnya.
            div.form-group
              label Password Baru
              input.form-control(type="password" ng-model="modalResetPwd.new_password" placeholder="Minimal 8 karakter")
          div.modal-actions
            button.btn-ghost(ng-click="closeResetPwd()") Batal
            button.btn-primary(ng-click="executeResetPwd()") Reset Password

      //- Section 7: Group Management (superadmin only)
      div.settings-section(ng-if="isSuperadmin")
        div.section-header
          i.bi.bi-collection
          h3 Group Management (Plat / Coil)
          span.role-badge Superadmin only
        div.section-body
          p.section-desc
            | Enable grouping berdasarkan tebal untuk kategori Plat / Coil.
            | Admin bisa edit harga per group, harga per lembar otomatis
            | dihitung dari berat masing-masing item.

          div.gm-categories
            div.gm-section-title KATEGORI
            div.empty-state(ng-if="categoryList.length === 0")
              i.bi.bi-info-circle
              |  Memuat daftar kategori...
            table.gm-cat-table(ng-if="categoryList.length > 0")
              thead
                tr
                  th Kategori
                  th(style="width:120px") Status
                  th(style="width:100px; text-align:center") Aksi
              tbody
                tr(ng-repeat="cat in categoryList")
                  td
                    strong {{ cat.cat_name }}
                    small.muted(style="display:block; font-size:11px; margin-top:2px")
                      | ID: {{ cat.cat_id }}
                  td
                    span.gm-status-badge(ng-class="cat.is_enabled ? 'enabled' : 'disabled'")
                      i.bi(ng-class="cat.is_enabled ? 'bi-check-circle-fill' : 'bi-x-circle'")
                      |  {{ cat.is_enabled ? 'Enabled' : 'Disabled' }}
                  td(style="text-align:center")
                    button.btn-toggle(ng-if="!cat.is_enabled" ng-click="enableGrouping(cat)")
                      | Enable
                    button.btn-toggle.btn-danger-soft(ng-if="cat.is_enabled" ng-click="disableGrouping(cat)")
                      | Disable

          div.gm-pricelist-section(ng-if="enabledCategories.length > 0")
            div.gm-section-title PRICELIST OPEN — INIT GROUPS
            p.section-desc.small
              | Pilih pricelist yang ingin di-initialize groups. Auto-detect
              | tebal dari nama item. Admin bisa preview sebelum confirm.
            div.empty-state(ng-if="openPricelists.length === 0")
              i.bi.bi-inbox
              |  Tidak ada pricelist OPEN di kategori yang enabled
            table.gm-pl-table(ng-if="openPricelists.length > 0")
              thead
                tr
                  th Kategori
                  th(style="width:80px") Revisi
                  th(style="width:120px") Status Init
                  th(style="width:140px; text-align:center") Aksi
              tbody
                tr(ng-repeat="pl in openPricelists")
                  td {{ pl.cat_name }}
                  td Rev.{{ pl.revision_no }}
                  td
                    span.gm-init-status(ng-if="pl.has_groups")
                      i.bi.bi-check-circle-fill
                      |  Initialized
                    span.gm-init-status.pending(ng-if="!pl.has_groups")
                      i.bi.bi-circle
                      |  Belum
                  td(style="text-align:center")
                    button.btn-primary.btn-small(ng-if="!pl.has_groups" ng-click="openInitPreview(pl)")
                      i.bi.bi-collection
                      |  Init Groups
                    button.btn-ghost.btn-small(ng-if="pl.has_groups" ng-click="goToEditGrouped(pl.id)")
                      i.bi.bi-pencil-square
                      |  Edit

      //- Modal: Preview Init Groups
      div.modal-overlay(ng-if="modalInitPreview" ng-click="closeInitPreview()")
        div.modal-card.modal-large(ng-click="$event.stopPropagation()")
          div.modal-header
            h3
              | Preview Init Groups:
              strong  {{ modalInitPreview.cat_name }}
              |  Rev.{{ modalInitPreview.pl_revision }}
            button.modal-close(ng-click="closeInitPreview()") ×
          div.modal-body
            div.loading-state(ng-if="modalInitPreview.loading")
              i.bi.bi-arrow-clockwise.spinning
              |  Memuat preview...
            div(ng-if="!modalInitPreview.loading && modalInitPreview.data")
              div.preview-summary
                div.preview-stat
                  strong.stat-num {{ modalInitPreview.data.total_items }}
                  span.stat-label Total item
                div.preview-stat.success
                  strong.stat-num {{ modalInitPreview.data.grouped_count }}
                  span.stat-label Auto-detected
                div.preview-stat.warning(ng-if="modalInitPreview.data.undetected.length > 0")
                  strong.stat-num {{ modalInitPreview.data.undetected.length }}
                  span.stat-label Tidak terdeteksi
                div.preview-stat
                  strong.stat-num {{ modalInitPreview.data.groups.length }}
                  span.stat-label Groups

              div.preview-groups
                div.preview-section-title GROUPS YANG AKAN DIBUAT
                div.preview-group-card(ng-repeat="g in modalInitPreview.data.groups")
                  div.pgc-header
                    span.pgc-thickness {{ g.thickness_label }}
                    span.pgc-count {{ g.items.length }} item
                  div.pgc-items
                    div.pgc-item(ng-repeat="it in g.items | limitTo:5")
                      span {{ it.i_name }}
                      small.muted ({{ it.i_weight }} kg)
                    div.pgc-item.muted(ng-if="g.items.length > 5")
                      em ...dan {{ g.items.length - 5 }} item lainnya

              div.preview-undetected(ng-if="modalInitPreview.data.undetected.length > 0")
                div.preview-section-title.warning
                  i.bi.bi-exclamation-triangle-fill
                  |  ITEM TIDAK TERDETEKSI ({{ modalInitPreview.data.undetected.length }})
                p.section-desc.small
                  | Tebal tidak bisa di-parse dari nama item ini.
                  | Item akan tampil terpisah dan perlu di-assign manual nanti.
                div.preview-undetected-list
                  div.pul-item(ng-repeat="it in modalInitPreview.data.undetected | limitTo:10")
                    span {{ it.i_name }}
                    small.muted ({{ it.i_weight }} kg)
                  div.pul-item.muted(ng-if="modalInitPreview.data.undetected.length > 10")
                    em ...dan {{ modalInitPreview.data.undetected.length - 10 }} item lainnya

          div.modal-actions
            button.btn-ghost(ng-click="closeInitPreview()") Batal
            button.btn-primary(
              ng-click="executeInitApply()"
              ng-disabled="modalInitPreview.executing || modalInitPreview.loading"
            )
              i.bi.bi-check-circle(ng-if="!modalInitPreview.executing")
              i.bi.bi-arrow-clockwise.spinning(ng-if="modalInitPreview.executing")
              |  {{ modalInitPreview.executing ? 'Menerapkan...' : 'Confirm & Apply' }}
