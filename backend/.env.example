PORT=3001

# ── DB 1: ERP (READ ONLY) ─────────────────────────────────────
# Database ERP eksternal, untuk ambil master data item & harga lama
ERP_DB_HOST=your-erp-server.example.com
ERP_DB_PORT=5432
ERP_DB_NAME=erp_db
ERP_DB_USER=readonly_user
ERP_DB_PASS=your_password_here

# ── DB 2: PLhamasa (READ + WRITE) ─────────────────────────────
# Database terpisah untuk simpan harga per kg & price log
PLM_DB_HOST=localhost
PLM_DB_PORT=5432
PLM_DB_NAME=plhamasa_db
PLM_DB_USER=postgres
PLM_DB_PASS=your_password_here

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_string
